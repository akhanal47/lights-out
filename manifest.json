{
  "manifest_version": 3,
  "name": "Lights Out",
  "version": "0.2.0",
  "permissions": ["storage", "activeTab"],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "icons": {
  "128": "icon/logo_128.png"
}
}